escribe una función en python. Debe recibir dos prámetros: list[str] y mask:str Debe pensar que la lista de str forma una matriz. Debe buscar la máscaraa(mask) en la matriz e indicar si aparece en algunas de las posibles 8 direcciones: Horizontal, vertical, diagonal izquierda, diagonal derecha, todas en ambas direcciones. Devolverá una lista de tuplas. Una lista list[tuple(int, int), str]. La lista tiene un elemento por cada vez que encuentra la máscara en un de las direcciones. Cada elemento contiene una tupla que indica la coordenada donde comienza la cadena encontrada y un código que indica la dirección: H horizontal, V Vertical, D1 diagonal hacia abajo D2 diagonal hacia arriba Si el texto está de derecha a izquierda, añadirá un signo "-" al código.

def find_mask(matrix: list[str], mask: str) -> list[tuple[tuple[int, int], str]]:
    """
    Busca `mask` dentro de una matriz representada como list[str].

    Coordenadas devueltas: (fila, columna), empezando en 0.

    Códigos de dirección:
        H   -> horizontal izquierda a derecha
        H-  -> horizontal derecha a izquierda
        V   -> vertical arriba a abajo
        V-  -> vertical abajo a arriba
        D1  -> diagonal hacia abajo-derecha
        D1- -> diagonal hacia arriba-izquierda
        D2  -> diagonal hacia arriba-derecha
        D2- -> diagonal hacia abajo-izquierda
    """

    if not matrix or not mask:
        return []

    rows = len(matrix)
    cols = len(matrix[0])

    for row in matrix:
        if len(row) != cols:
            raise ValueError("Todas las filas de la matriz deben tener la misma longitud")

    directions = [
        (0, 1, "H"),      # izquierda -> derecha
        (0, -1, "H-"),    # derecha -> izquierda

        (1, 0, "V"),      # arriba -> abajo
        (-1, 0, "V-"),    # abajo -> arriba

        (1, 1, "D1"),     # diagonal abajo-derecha
        (-1, -1, "D1-"),  # diagonal arriba-izquierda

        (-1, 1, "D2"),    # diagonal arriba-derecha
        (1, -1, "D2-"),   # diagonal abajo-izquierda
    ]

    result: list[tuple[tuple[int, int], str]] = []
    mask_len = len(mask)

    def fits(row: int, col: int, drow: int, dcol: int) -> bool:
        end_row = row + drow * (mask_len - 1)
        end_col = col + dcol * (mask_len - 1)

        return 0 <= end_row < rows and 0 <= end_col < cols

    for row in range(rows):
        for col in range(cols):
            for drow, dcol, code in directions:
                if not fits(row, col, drow, dcol):
                    continue

                found = True

                for i in range(mask_len):
                    current_row = row + drow * i
                    current_col = col + dcol * i

                    if matrix[current_row][current_col] != mask[i]:
                        found = False
                        break

                if found:
                    result.append(((row, col), code))

    return result
